{
  "name": "vsc-or",
  "displayName": "OR",
  "description": "Receive execution bundles and submit evidence from your IDE",
  "version": "0.1.3",
  "publisher": "raftio",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:or.bundleTree"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "or",
          "title": "OR",
          "icon": "$(symbol-structure)"
        }
      ]
    },
    "views": {
      "or": [
        {
          "id": "or.bundleTree",
          "name": "Execution Bundle"
        }
      ]
    },
    "commands": [
      {
        "command": "or.fetchBundle",
        "title": "OR: Fetch Bundle",
        "icon": "$(cloud-download)"
      },
      {
        "command": "or.submitEvidence",
        "title": "OR: Submit Evidence",
        "icon": "$(beaker)"
      },
      {
        "command": "or.disconnect",
        "title": "OR: Disconnect"
      },
      {
        "command": "or.refreshBundle",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "or.executeTask",
        "title": "OR: Execute Task",
        "icon": "$(play)"
      },
      {
        "command": "or.executeBundle",
        "title": "OR: Execute Bundle",
        "icon": "$(run-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "or.executeBundle",
          "when": "view == or.bundleTree",
          "group": "navigation"
        },
        {
          "command": "or.fetchBundle",
          "when": "view == or.bundleTree",
          "group": "navigation"
        },
        {
          "command": "or.refreshBundle",
          "when": "view == or.bundleTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "or.executeBundle",
          "when": "view == or.bundleTree && viewItem == bundle",
          "group": "inline"
        },
        {
          "command": "or.executeTask",
          "when": "view == or.bundleTree && viewItem == task",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "OR",
      "properties": {
        "or.apiUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "Base URL of the OR API"
        },
        "or.apiToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authenticating with the OR API"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "package": "npm run build -- --minify",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
